# Solidview — Environment Variables
#
# All keys are optional. Users can provide their own keys via the UI.
# Server-side keys enable the app to work without user-provided keys.

# Etherscan API key (primary — used for Ethereum mainnet)
# Register: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# Arbiscan API key (Arbitrum)
# Register: https://arbiscan.io/myapikey
ARBISCAN_API_KEY=

# Optimism Etherscan API key
# Register: https://optimistic.etherscan.io/myapikey
OPTIMISM_ETHERSCAN_API_KEY=

# Basescan API key (Base)
# Register: https://basescan.org/myapikey
BASESCAN_API_KEY=

# Polygonscan API key (Polygon)
# Register: https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=

# Custom RPC URLs (optional — override default public endpoints)
# RPC_URL_ETHEREUM=
# RPC_URL_ARBITRUM=
# RPC_URL_OPTIMISM=
# RPC_URL_BASE=
# RPC_URL_POLYGON=
